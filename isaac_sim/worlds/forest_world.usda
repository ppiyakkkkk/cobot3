#usda 1.0
(
    defaultPrim = "World"
    doc = "Self-contained forest rescue environment for Isaac Sim 5.1 and Pegasus Simulator. Units are meters, Z-up."
    metersPerUnit = 1
    upAxis = "Z"
)

# 이 파일은 외부 에셋 없이 바로 열 수 있는 산림 구조 드론 시험 환경이다.
# 중앙 20 x 20 m는 기존 8 x 8 m 수색 경로와 조난자 (4, 4, 0) 시험을 위해 평탄하게 유지한다.
# 외곽은 높아지는 산지형이며, 나무 줄기·바위·지형에는 단순 충돌체가 적용되어 있다.

def Xform "World"
{
    def PhysicsScene "PhysicsScene"
    {
        vector3f physics:gravityDirection = (0, 0, -1)
        float physics:gravityMagnitude = 9.81
    }

    def DistantLight "Sun"
    {
        float inputs:angle = 0.8
        color3f inputs:color = (1.0, 0.94, 0.82)
        float inputs:intensity = 2800
        double3 xformOp:rotateXYZ = (35, -25, -35)
        uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
    }

    def DomeLight "Sky"
    {
        color3f inputs:color = (0.36, 0.48, 0.62)
        float inputs:intensity = 350
    }

    def Xform "Environment"
    {
