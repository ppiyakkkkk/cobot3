                (-15, -10, 2.4), (-10, -10, 0.0), (-5, -10, 0.0), (0, -10, 0.0), (5, -10, 0.0), (10, -10, 0.0), (15, -10, 2.5),
                (-15, -5, 2.0), (-10, -5, 0.0), (-5, -5, 0.0), (0, -5, 0.0), (5, -5, 0.0), (10, -5, 0.0), (15, -5, 2.1),
                (-15, 0, 1.8), (-10, 0, 0.0), (-5, 0, 0.0), (0, 0, 0.0), (5, 0, 0.0), (10, 0, 0.0), (15, 0, 1.9),
